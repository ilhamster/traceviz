{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM"],
    "types": ["jasmine", "node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@traceviz/client-core": ["../core/index.ts"],
      "@traceviz/client-core/*": ["../core/*"]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
